INSTANCE_ID=local
TZ=America/Bogota
FLOCI_IMAGE=floci/floci:1.5.30
FLOCI_AWS_ENDPOINT_URL=http://floci:4566
FLOCI_STORAGE_MODE=persistent
FLOCI_STORAGE_PERSISTENT_PATH=/app/data
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SECRET_INTERNAL_API_TOKEN_NAME=wa-agent-core/local/internal-api-token
AGENT_URL=http://agent:8000
AGENT_REQUEST_TIMEOUT_MS=30000
BRIDGE_ACL_MODE=open
BRIDGE_ALLOWED_NUMBERS=
BRIDGE_ERROR_REPLY=No pude responder en este momento. Intenta de nuevo.
TYPING_ENABLED=1
TYPING_MIN_MS=600
AGENT_MEMORY_LIMIT=256m
BRIDGE_MEMORY_LIMIT=1g
FLOCI_MEMORY_LIMIT=384m
